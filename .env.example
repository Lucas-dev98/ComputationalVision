# Variáveis de Ambiente - Copie para .env e configure

## Frontend
REACT_APP_API_URL=http://localhost:8080
REACT_APP_OCR_URL=http://localhost:5001

## Inventory Service (Go)
DATABASE_URL=postgres://inventory:inventory_dev@postgres:5432/inventory_db?sslmode=disable
REDIS_URL=redis://redis:6379
PORT=8080
LOG_LEVEL=info
ENV=development

## OCR Service (Python)
HOST=0.0.0.0
PORT=5001
LOG_LEVEL=INFO
ENV=development

## PostgreSQL
POSTGRES_USER=inventory
POSTGRES_PASSWORD=inventory_dev
POSTGRES_DB=inventory_db

## Redis
REDIS_PASSWORD=
